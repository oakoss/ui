{
  "name": "oakoss-ui",
  "version": "0.0.0",
  "private": true,
  "description": "Enterprise OSS React design system built on React Aria Components and distributed via a shadcn-compatible registry.",
  "homepage": "https://github.com/oakoss/ui#readme",
  "bugs": {
    "url": "https://github.com/oakoss/ui/issues"
  },
  "license": "MIT",
  "author": "oakoss contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oakoss/ui.git"
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "commit": "czg",
    "commitlint": "commitlint --edit",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:md": "markdownlint-cli2 '**/*.md'",
    "lint:md:fix": "markdownlint-cli2 --fix '**/*.md'",
    "release": "changeset publish",
    "release:version": "changeset version && pnpm install --lockfile-only && pnpm format",
    "test": "turbo run test",
    "test:watch": "turbo watch test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/config-conventional": "^21.0.1",
    "commitlint": "^21.0.1",
    "czg": "^1.13.1",
    "lefthook": "^2.1.8",
    "markdownlint-cli2": "^0.22.1",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=24.16.0",
    "pnpm": ">=11.4.0"
  },
  "packageManager": "pnpm@11.4.0"
}
