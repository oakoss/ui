{
  "name": "ui",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "format": "prettier -uwl --cache .",
    "format:check": "prettier -uc --cache .",
    "postinstall": "pnpm run lint:ws",
    "lint": "turbo run lint -- --max-warnings 0 --cache --cache-location node_modules/.cache/eslint/.eslintcache",
    "lint:fix": "turbo run lint -- --fix --cache --cache-location node_modules/.cache/eslint/.eslintcache",
    "lint:md": "markdownlint-cli2 '**/*.md'",
    "lint:md:fix": "markdownlint-cli2 '**/*.md' --fix",
    "lint:ws": "sherif",
    "typecheck": "turbo run typecheck"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "devDependencies": {
    "@commitlint/config-conventional": "20.5.0",
    "commitlint": "20.5.2",
    "cz-git": "1.13.0",
    "lefthook": "2.1.6",
    "markdownlint-cli2": "0.22.1",
    "prettier": "3.8.3",
    "prettier-plugin-packagejson": "2.5.22",
    "sherif": "1.11.1",
    "turbo": "2.9.6",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=25.1.0"
  }
}
